{
	"compilerOptions": {
	"target": "es2015",
	"lib": [
		"dom",
		"dom.iterable",
		"esnext"
	],
	"allowJs": true,
	"skipLibCheck": true,
	"strict": false,
	"noEmit": true,
	"incremental": true,
	"esModuleInterop": true,
	"module": "esnext",
	"moduleResolution": "bundler",
	"resolveJsonModule": true,
	"isolatedModules": true,
	"jsx": "react-jsx",
	"plugins": [
		{
			"name": "next"
		}
	],
	"paths": {
		"@/*": ["./src/*"]
	},
	"strictNullChecks": true
	},
	"include": [
		"next-env.d.ts",
		".next/types/**/*.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/dev/types/**/*.ts"
	],
	"exclude": [
		"node_modules"
	]
}
